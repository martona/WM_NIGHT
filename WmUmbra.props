<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- Single source of truth for where the umbra static library lives. During the transition
       WM_NIGHT consumes umbra from a sibling working copy via project reference (NOT vcpkg);
       retarget here if it moves or later becomes a package. Path is relative to this .props,
       i.e. to the WM_NIGHT repo root. Override from the build with /p:WmUmbraDir=... if needed. -->
  <PropertyGroup>
    <WmUmbraDir Condition="'$(WmUmbraDir)' == ''">$(MSBuildThisFileDirectory)..\WM_UMBRA</WmUmbraDir>
  </PropertyGroup>
</Project>
