// SPDX-License-Identifier: MIT
//
// WM_NIGHT resources. Version fields are sourced from version.h so the product
// version has exactly one control point.

#include <windows.h>
#include "resource.h"
#include "version.h"

/////////////////////////////////////////////////////////////////////////////
// Icon. The first (lowest id) ICON becomes the application icon shown by the
// shell; it is also the source for the notification-area (tray) icon.
// Path is relative to this .rc file (src\ -> ..\resources).
IDI_APPICON ICON "..\\resources\\WM_NIGHT.ico"

/////////////////////////////////////////////////////////////////////////////
// Version information (all values come from version.h).
VS_VERSION_INFO VERSIONINFO
 FILEVERSION    WMN_VERSION_DIGITAL
 PRODUCTVERSION WMN_VERSION_DIGITAL
 FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS      VS_FF_DEBUG
#else
 FILEFLAGS      0x0L
#endif
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_APP
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"          // U.S. English (0x0409), Unicode (1200 = 0x04B0)
        BEGIN
            VALUE "CompanyName",      WMN_COMPANY_NAME
            VALUE "FileDescription",  WMN_FILE_DESCRIPTION
            VALUE "FileVersion",      WMN_VERSION_STR
            VALUE "InternalName",     WMN_INTERNAL_NAME
            VALUE "LegalCopyright",   WMN_COPYRIGHT
            VALUE "OriginalFilename", WMN_ORIGINAL_FILENAME
            VALUE "ProductName",      WMN_PRODUCT_NAME
            VALUE "ProductVersion",   WMN_VERSION_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

/////////////////////////////////////////////////////////////////////////////
// About dialog. The 128px icon is set at runtime (STM_SETICON); the SysLinks open
// the project + component repos. Dark-themed via umbra in the dialog procedure.
IDD_ABOUT DIALOGEX 0, 0, 320, 196
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About WM_NIGHT"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    ICON            IDI_APPICON, IDC_ABOUT_ICON, 16, 20, 20, 20
    LTEXT           "WM_NIGHT", IDC_ABOUT_TITLE, 104, 20, 200, 24
    LTEXT           "Version 0.0.0.0", IDC_ABOUT_VERSION, 104, 46, 200, 10
    LTEXT           "Copyright (c) 2026 Marton Anka. Released under the MIT License.", IDC_ABOUT_COPYRIGHT, 104, 60, 204, 20
    CONTROL         "<a href=""https://github.com/martona/WM_NIGHT"">github.com/martona/WM_NIGHT</a>", IDC_ABOUT_LINK, "SysLink", WS_TABSTOP, 104, 82, 204, 10
    LTEXT           "Built with these open-source components:", IDC_STATIC, 16, 112, 292, 10
    CONTROL         "Microsoft Detours - MIT License (<a href=""https://github.com/microsoft/Detours"">project</a>)", IDC_ABOUT_DETOURS, "SysLink", WS_TABSTOP, 24, 126, 284, 10
    CONTROL         "WM_UMBRA - MIT / BSD-3-Clause (<a href=""https://github.com/martona/WM_UMBRA"">project</a>)", IDC_ABOUT_UMBRA, "SysLink", WS_TABSTOP, 24, 138, 284, 10
    DEFPUSHBUTTON   "OK", IDOK, 256, 172, 50, 14
END
