<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug|ARM64">
      <Configuration>Debug</Configuration>
      <Platform>ARM64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|ARM64">
      <Configuration>Release</Configuration>
      <Platform>ARM64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <Keyword>Win32Proj</Keyword>
    <ProjectGuid>{4B0D8F26-9C3E-4A7B-8D2F-3E5071829304}</ProjectGuid>
    <RootNamespace>WMNIGHT</RootNamespace>
    <ProjectName>WM_NIGHT</ProjectName>
    <TargetName>WM_NIGHT</TargetName>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
    <UseDebugLibraries Condition="'$(Configuration)'=='Debug'">true</UseDebugLibraries>
    <UseDebugLibraries Condition="'$(Configuration)'=='Release'">false</UseDebugLibraries>
    <WholeProgramOptimization Condition="'$(Configuration)'=='Release'">true</WholeProgramOptimization>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <!-- Points at the umbra library working copy (../WM_UMBRA): the host links umbra so its OWN
       UI (tray popup menu, message boxes) follows dark mode. Still no Detours / vcpkg here — the
       inline hooks (Detours) live only in the payload; the host needs just dbghelp for the
       one-time dui70 symbol resolution. -->
  <Import Project="WmUmbra.props" />
  <PropertyGroup Label="Vcpkg">
    <VcpkgEnabled>false</VcpkgEnabled>
  </PropertyGroup>
  <ImportGroup Label="PropertySheets">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props"
            Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')"
            Label="LocalAppDataPlatform" />
  </ImportGroup>

  <PropertyGroup>
    <OutDir>$(SolutionDir)build\$(Configuration)\$(Platform)\</OutDir>
    <IntDir>$(OutDir)intermediate\WM_NIGHT\</IntDir>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level4</WarningLevel>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <ConformanceMode>true</ConformanceMode>
      <!-- C++/WinRT projection headers (system XAML Islands) ship in the SDK; no NuGet needed.
           /EHsc is required by C++/WinRT. -->
      <ExceptionHandling>Sync</ExceptionHandling>
      <AdditionalIncludeDirectories>$(WmUmbraDir)\include;$(WindowsSdkDir)Include\$(WindowsTargetPlatformVersion)\cppwinrt;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions>UNICODE;_UNICODE;WIN32_LEAN_AND_MEAN;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <PreprocessorDefinitions Condition="'$(Configuration)'=='Debug'">_DEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <PreprocessorDefinitions Condition="'$(Configuration)'=='Release'">NDEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <RuntimeLibrary Condition="'$(Configuration)'=='Debug' and '$(UmbraCRT)'=='DLL'">MultiThreadedDebugDLL</RuntimeLibrary>
      <RuntimeLibrary Condition="'$(Configuration)'=='Debug' and '$(UmbraCRT)'!='DLL'">MultiThreadedDebug</RuntimeLibrary>
      <RuntimeLibrary Condition="'$(Configuration)'=='Release' and '$(UmbraCRT)'=='DLL'">MultiThreadedDLL</RuntimeLibrary>
      <RuntimeLibrary Condition="'$(Configuration)'=='Release' and '$(UmbraCRT)'!='DLL'">MultiThreaded</RuntimeLibrary>
      <AdditionalOptions>/utf-8 %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <!-- asInvoker + uiAccess: reach an elevated regedit without elevating, IF signed
           (post-build below) and launched from a trusted path. The linker embeds the
           trustInfo manifest; no separate .manifest file (avoids the mt.exe UAC clash). -->
      <EnableUAC>true</EnableUAC>
      <UACExecutionLevel>AsInvoker</UACExecutionLevel>
      <UACUIAccess>true</UACUIAccess>
    </Link>
    <ResourceCompile>
      <PreprocessorDefinitions Condition="'$(Configuration)'=='Debug'">_DEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <PreprocessorDefinitions Condition="'$(Configuration)'=='Release'">NDEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ResourceCompile>
    <!-- Merge a compatibility/maxversiontested fragment (XAML Islands needs it) into the linker's
         UAC manifest. Fragment-only (no trustInfo), so mt.exe merges it without the UAC clash. -->
    <Manifest>
      <AdditionalManifestFiles>src\WM_NIGHT.manifest;%(AdditionalManifestFiles)</AdditionalManifestFiles>
    </Manifest>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="src\WM_NIGHT.cpp" />
    <ClCompile Include="src\SettingsWindow.cpp" />
    <ClCompile Include="src\AboutDialog.cpp" />
    <ClCompile Include="src\whitelist.cpp" />
  </ItemGroup>

  <ItemGroup>
    <ResourceCompile Include="src\WM_NIGHT.rc" />
  </ItemGroup>

  <ItemGroup>
    <ClInclude Include="src\resource.h" />
    <ClInclude Include="src\version.h" />
    <ClInclude Include="src\SettingsWindow.h" />
    <ClInclude Include="src\AboutDialog.h" />
    <ClInclude Include="src\whitelist.h" />
  </ItemGroup>

  <!-- Build the payload first (ordering only; the host LoadLibrary's it at runtime, so
       no link dependency) — and so the sign step below sees both artifacts. -->
  <ItemGroup>
    <!-- umbra static library (../WM_UMBRA): LINKED into the host for its own dark UI. -->
    <ProjectReference Include="$(WmUmbraDir)\project\umbra.vcxproj">
      <Project>{40E6196F-E54E-4BFF-8A94-449BB8E2E34F}</Project>
    </ProjectReference>
    <ProjectReference Include="WM_NIGHThook.vcxproj">
      <Project>{3A9C7E15-8B2D-4F6A-9C1E-2D4F60718293}</Project>
      <LinkLibraryDependencies>false</LinkLibraryDependencies>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
  </ItemGroup>

  <!-- Code signing (Azure Trusted Signing via the `sign` dotnet tool). uiAccess is honored
       only for a signed binary, so sign both the host and the payload. No-ops on boxes
       without the ARTIFACT_SIGNING_* env. -->
  <Target Name="SignArtifacts" AfterTargets="Build" Condition="'$(ARTIFACT_SIGNING_ENDPOINT)'!=''">
    <Message Importance="high" Text="Signing WM_NIGHT.exe + WM_NIGHThook.dll (Trusted Signing)..." />
    <Exec Command="sign code artifact-signing -b &quot;$(OutDir).&quot; -ase &quot;$(ARTIFACT_SIGNING_ENDPOINT)&quot; -asa &quot;$(ARTIFACT_SIGNING_ACCOUNT)&quot; WM_NIGHT.exe WM_NIGHThook.dll -v Information -ascp &quot;$(ARTIFACT_SIGNING_CERTIFICATE_PROFILE)&quot;" />
  </Target>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
